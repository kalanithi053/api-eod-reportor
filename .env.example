PORT=3000

MONGODB_URI=mongodb://localhost:27017/nest-auth-app

JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=1d

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Optional: where to redirect with ?token=... after a successful login.
# If unset, the callback returns JSON instead of redirecting.
FRONTEND_REDIRECT_URL=http://localhost:5173/auth/callback
